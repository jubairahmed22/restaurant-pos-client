{
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "framework": "nextjs",
  "env": {
    "NEXT_PUBLIC_SITE_URL": "https://rinrestaurant.com.au",
    "NEXT_PUBLIC_SOCKET_URL": "https://ortazz.com.au",
    "BACKEND_URL": "https://ortazz.com.au"
  },
  "headers": [
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
